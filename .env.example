# ──────────────────────────────────────────────────────────────────────────────
# MoodMind — Environment Variables
# Copy this file to .env and fill in your own values before running locally.
# NEVER commit your real .env file (it is already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Clerk — authentication (https://dashboard.clerk.com)
# Create an application, then copy keys from API Keys page.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection string (recommended: Neon free tier — https://neon.tech)
# Without this, wellness data stays in memory and is lost on restart.
DATABASE_URL=postgresql://postgres:password@localhost:5432/moodmind

# Secret used to sign express-session cookies (future use).
SESSION_SECRET=replace-me-with-a-long-random-string

# Public app URL (set to your Vercel URL in production)
APP_URL=http://localhost:5000

# (Optional) Port for the local dev server. Defaults to 5000 if not set.
# PORT=5000
