# ──────────────────────────────────────────────────────────────────────────────
# MoodMind — Environment Variables
# Copy this file to .env and fill in your own values before running locally.
# NEVER commit your real .env file (it is already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (recommended: Neon free tier — https://neon.tech)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# Without this, user accounts are stored in memory and lost on restart.
DATABASE_URL=postgresql://postgres:password@localhost:5432/moodmind

# Secret used to sign express-session cookies (future use).
# Generate a strong random value: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Resend — verification code emails (https://resend.com)
# Without this key, codes are printed to the server console in dev.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address — use onboarding@resend.dev for testing (only delivers to your Resend account email)
# For production, verify your own domain and use e.g. MoodMind <noreply@yourdomain.com>
RESEND_FROM_EMAIL=MoodMind <onboarding@resend.dev>
# Public app URL (set to your Vercel URL in production)
APP_URL=http://localhost:5000

# (Optional) Port for the local dev server. Defaults to 5000 if not set.
# PORT=5000
